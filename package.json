{
  "name": "minimal-react-router-starter",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "docker:build": "docker build -t minimal-react-router-starter-image .",
    "docker:start": "docker run -p 3000:3000 --name minimal-react-router-starter minimal-react-router-starter-image",
    "docker:stop": "docker stop minimal-react-router-starter && docker rm minimal-react-router-starter",
    "typecheck": "react-router typegen && tsc"
  },
  "dependencies": {
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "@react-router/node": "7.12.0",
    "@react-router/serve": "7.12.0",
    "isbot": "^5.1.31",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "7.12.0",
    "remix-utils": "^9.0.1",
    "sanitize-html": "^2.17.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@react-router/dev": "7.12.0",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^22",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.0",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
